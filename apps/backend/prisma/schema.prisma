generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model agent_pipeline_runs {
  id            String   @id
  owner_id      String
  project_id    String
  title         String
  goal          String?
  status        String
  stages_json   String
  progress_json String?
  result_json   String?
  error_message String?
  created_at    String
  updated_at    String
  started_at    String?
  finished_at   String?
  users         users    @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects      projects @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id, project_id, updated_at(sort: Desc)], map: "idx_agent_pipeline_runs_owner_project_updated")
  @@index([owner_id, status, updated_at(sort: Desc)], map: "idx_agent_pipeline_runs_owner_status_updated")
}

model agent_presets {
  id              String  @id
  key             String  @unique
  name            String
  description     String?
  system_prompt   String?
  opening_message String?
  skill_ids       String?
  enabled         Int     @default(1)
  visible         Int     @default(1)
  sort_order      Int?
  created_at      String
  updated_at      String

  @@index([enabled, visible, sort_order], map: "idx_agent_presets_enabled_visible_sort")
}

model agent_skills {
  id          String  @id
  key         String  @unique
  name        String
  description String?
  content     String
  enabled     Int     @default(1)
  visible     Int     @default(1)
  sort_order  Int?
  created_at  String
  updated_at  String

  @@index([enabled, visible, sort_order], map: "idx_agent_skills_enabled_visible_sort")
}

model api_keys {
  id              String  @id
  owner_id        String
  label           String
  key_prefix      String
  key_hash        String  @unique(map: "idx_api_keys_hash")
  allowed_origins String
  enabled         Int     @default(1)
  last_used_at    String?
  created_at      String
  updated_at      String
  users           users   @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id], map: "idx_api_keys_owner")
}

model api_request_logs {
  id          String  @id
  user_id     String?
  api_key_id  String?
  method      String
  path        String
  status      Int?
  stage       String?
  aborted     Int     @default(0)
  started_at  String
  finished_at String?
  duration_ms Int?
  trace_json  String?
  created_at  String
  updated_at  String

  @@index([path, started_at], map: "idx_api_request_logs_path_started_at")
  @@index([started_at], map: "idx_api_request_logs_started_at")
  @@index([user_id, started_at], map: "idx_api_request_logs_user_started_at")
}

model assets {
  id         String    @id
  name       String
  data       String?
  owner_id   String
  project_id String?
  created_at String
  updated_at String
  users      users     @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects   projects? @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id], map: "idx_assets_owner")
  @@index([project_id], map: "idx_assets_project")
}

model commerce_dictionaries {
  id         String  @id
  owner_id   String
  dict_type  String
  code       String
  name       String
  value_json String?
  enabled    Int     @default(1)
  sort_order Int     @default(0)
  created_at String
  updated_at String
  users      users   @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([owner_id, dict_type, code])
  @@index([owner_id, dict_type, sort_order, code], map: "idx_commerce_dict_owner_type_sort")
}

model detail_page_evolution_runs {
  id            String @id
  owner_id      String
  min_feedbacks Int
  action        String
  metrics_json  String
  created_at    String
  users         users  @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id, created_at(sort: Desc)], map: "idx_detail_page_evolution_runs_owner_created")
}

model detail_page_feedback_logs {
  id                  String              @id
  owner_id            String
  generation_id       String?
  sample_id           String
  score_overall       Int
  score_structure     Int?
  score_visual        Int?
  score_conversion    Int?
  edit_ratio          Float?              @db.Real
  note                String?
  created_at          String
  users               users               @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  detail_page_samples detail_page_samples @relation(fields: [sample_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([owner_id, created_at(sort: Desc)], map: "idx_detail_page_feedback_logs_owner_created")
  @@index([owner_id, sample_id, created_at(sort: Desc)], map: "idx_detail_page_feedback_logs_owner_sample")
}

model detail_page_retrieval_logs {
  id                  String              @id
  owner_id            String
  query_text          String?
  category            String?
  sample_id           String
  rank_no             Int                 @default(0)
  score               Float               @default(0) @db.Real
  created_at          String
  users               users               @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  detail_page_samples detail_page_samples @relation(fields: [sample_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([owner_id, created_at(sort: Desc)], map: "idx_detail_page_retrieval_logs_owner_created")
  @@index([owner_id, sample_id, created_at(sort: Desc)], map: "idx_detail_page_retrieval_logs_owner_sample")
}

model detail_page_samples {
  id                         String                       @id
  owner_id                   String
  title                      String
  category                   String
  tags_json                  String                       @default("[]")
  source                     String?
  image_url                  String?
  summary                    String?
  modules_json               String?
  copy_json                  String?
  style_json                 String?
  score_quality              Float                        @default(0) @db.Real
  score_visual               Float                        @default(0) @db.Real
  score_conversion           Float                        @default(0) @db.Real
  usage_count                Int                          @default(0)
  last_used_at               String?
  created_at                 String
  updated_at                 String
  detail_page_feedback_logs  detail_page_feedback_logs[]
  detail_page_retrieval_logs detail_page_retrieval_logs[]
  users                      users                        @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id, category, updated_at(sort: Desc)], map: "idx_detail_page_samples_owner_category")
  @@index([owner_id, updated_at(sort: Desc)], map: "idx_detail_page_samples_owner_updated")
}

model email_login_codes {
  id         String  @id
  email      String
  code_salt  String
  code_hash  String
  expires_at String
  used_at    String?
  created_at String
  updated_at String

  @@index([email, created_at], map: "idx_email_login_codes_email_created_at")
  @@index([email, expires_at], map: "idx_email_login_codes_email_expires_at")
}

model flow_versions {
  id                  String                @id
  flow_id             String
  name                String
  data                String
  user_id             String?
  created_at          String
  flows               flows                 @relation(fields: [flow_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workflow_executions workflow_executions[]

  @@index([flow_id], map: "idx_flow_versions_flow_id")
  @@index([user_id], map: "idx_flow_versions_user_id")
}

model flows {
  id                  String                @id
  name                String
  data                String
  owner_id            String?
  project_id          String?
  created_at          String
  updated_at          String
  flow_versions       flow_versions[]
  users               users?                @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects            projects?             @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workflow_executions workflow_executions[]

  @@index([owner_id], map: "idx_flows_owner_id")
  @@index([project_id], map: "idx_flows_project_id")
}

model chapters {
  id                     String   @id
  owner_id               String
  project_id             String
  chapter_index          Int
  title                  String
  summary                String?
  status                 String
  sort_order             Int
  cover_asset_id         String?
  continuity_context     String?
  style_profile_override String?
  legacy_chunk_index     Int?
  source_book_id         String?
  source_book_chapter    Int?
  last_worked_at         String?
  created_at             String
  updated_at             String
  users                  users    @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects               projects @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([project_id, chapter_index], map: "idx_chapters_project_index_unique")
  @@index([owner_id, project_id, sort_order], map: "idx_chapters_owner_project_sort")
  @@index([project_id, last_worked_at], map: "idx_chapters_project_last_worked")
}

model llm_node_presets {
  id          String  @id
  owner_id    String?
  scope       String
  preset_type String
  title       String
  prompt      String
  description String?
  enabled     Int     @default(1)
  sort_order  Int?
  created_at  String
  updated_at  String
  users       users?  @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id, preset_type], map: "idx_llm_node_presets_owner_type")
  @@index([scope, preset_type, enabled], map: "idx_llm_node_presets_scope_type_enabled")
}

model merchants {
  id           String         @id
  owner_id     String         @unique
  name         String
  status       String         @default("active")
  created_at   String
  updated_at   String
  users        users          @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders       orders[]
  product_skus product_skus[]
  products     products[]

  @@index([owner_id], map: "idx_merchants_owner_id")
  @@index([status], map: "idx_merchants_status")
}

model model_catalog_mappings {
  id                    String                @id
  vendor_key            String
  task_kind             String
  name                  String
  enabled               Int                   @default(1)
  request_mapping       String?
  response_mapping      String?
  created_at            String
  updated_at            String
  model_catalog_vendors model_catalog_vendors @relation(fields: [vendor_key], references: [key], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendor_key, task_kind, name])
  @@index([vendor_key, task_kind], map: "idx_model_catalog_mappings_vendor_kind")
}

model model_catalog_models {
  model_key             String
  vendor_key            String
  model_alias           String?
  label_zh              String
  kind                  String
  enabled               Int                   @default(1)
  meta                  String?
  created_at            String
  updated_at            String
  model_catalog_vendors model_catalog_vendors @relation(fields: [vendor_key], references: [key], onDelete: Cascade, onUpdate: NoAction)

  @@id([vendor_key, model_key])
  @@index([enabled], map: "idx_model_catalog_models_enabled")
  @@index([vendor_key, kind], map: "idx_model_catalog_models_vendor_kind")
}

model model_catalog_vendor_api_keys {
  vendor_key            String                @id
  api_key               String
  enabled               Int                   @default(1)
  created_at            String
  updated_at            String
  model_catalog_vendors model_catalog_vendors @relation(fields: [vendor_key], references: [key], onDelete: Cascade, onUpdate: NoAction)
}

model model_catalog_vendors {
  key                           String                         @id
  name                          String
  enabled                       Int                            @default(1)
  base_url_hint                 String?
  auth_type                     String                         @default("bearer")
  auth_header                   String?
  auth_query_param              String?
  meta                          String?
  created_at                    String
  updated_at                    String
  model_catalog_mappings        model_catalog_mappings[]
  model_catalog_models          model_catalog_models[]
  model_catalog_vendor_api_keys model_catalog_vendor_api_keys?
}

model model_credit_cost_specs {
  model_key  String
  spec_key   String
  cost       Int
  enabled    Int    @default(1)
  created_at String
  updated_at String

  @@id([model_key, spec_key])
  @@index([model_key], map: "idx_model_credit_cost_specs_model_key")
}

model model_credit_costs {
  model_key  String @id
  cost       Int
  enabled    Int    @default(1)
  created_at String
  updated_at String
}

model model_endpoints {
  id              String          @id
  provider_id     String
  key             String
  label           String
  base_url        String
  shared          Int             @default(0)
  created_at      String
  updated_at      String
  model_providers model_providers @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([provider_id, key])
  @@index([provider_id], map: "idx_model_endpoints_provider_id")
}

model model_profiles {
  id              String          @id
  owner_id        String
  provider_id     String
  name            String
  kind            String
  model_key       String
  settings        String?
  created_at      String
  updated_at      String
  users           users           @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  model_providers model_providers @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([owner_id], map: "idx_model_profiles_owner")
  @@index([provider_id], map: "idx_model_profiles_provider")
}

model model_providers {
  id              String            @id
  name            String
  vendor          String
  base_url        String?
  shared_base_url Int               @default(0)
  owner_id        String
  created_at      String
  updated_at      String
  model_endpoints model_endpoints[]
  model_profiles  model_profiles[]
  users           users             @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  model_tokens    model_tokens[]

  @@index([owner_id], map: "idx_model_providers_owner_id")
  @@index([vendor], map: "idx_model_providers_vendor")
}

model model_tokens {
  id                     String                @id
  provider_id            String
  label                  String
  secret_token           String
  user_agent             String?
  user_id                String
  enabled                Int                   @default(1)
  shared                 Int                   @default(0)
  shared_failure_count   Int                   @default(0)
  shared_last_failure_at String?
  shared_disabled_until  String?
  created_at             String
  updated_at             String
  model_providers        model_providers       @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                  users                 @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task_token_mappings    task_token_mappings[]

  @@index([provider_id], map: "idx_model_tokens_provider_id")
  @@index([shared], map: "idx_model_tokens_shared")
  @@index([user_id], map: "idx_model_tokens_user_id")
}

model order_entitlements {
  id               String      @id
  owner_id         String
  order_id         String
  order_item_id    String
  product_id       String
  entitlement_type String
  status           String
  result_json      String?
  created_at       String
  updated_at       String
  orders           orders      @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items      order_items @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users       @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products         products    @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([order_item_id, entitlement_type])
  @@index([owner_id, created_at(sort: Desc)], map: "idx_order_entitlements_owner_created")
}

model order_items {
  id                       String               @id
  order_id                 String
  product_id               String
  sku_id                   String?
  title_snapshot           String
  sku_name_snapshot        String?
  unit_price_cents         Int                  @default(0)
  quantity                 Int                  @default(1)
  total_price_cents        Int                  @default(0)
  cover_image_url_snapshot String?
  created_at               String
  updated_at               String
  order_entitlements       order_entitlements[]
  orders                   orders               @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products                 products             @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_skus             product_skus?        @relation(fields: [sku_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order")
  @@index([product_id], map: "idx_order_items_product")
}

model order_status_events {
  id           String  @id
  order_id     String
  owner_id     String
  from_status  String?
  to_status    String
  event_type   String
  reason       String?
  payload_json String?
  created_at   String
  orders       orders  @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users   @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id, created_at], map: "idx_order_status_events_order_created")
  @@index([owner_id, created_at(sort: Desc)], map: "idx_order_status_events_owner_created")
}

model orders {
  id                  String                @id
  owner_id            String
  merchant_id         String
  order_no            String                @unique
  status              String                @default("pending_payment")
  payment_status      String                @default("unpaid")
  currency            String                @default("CNY")
  total_amount_cents  Int                   @default(0)
  paid_amount_cents   Int                   @default(0)
  refund_amount_cents Int                   @default(0)
  refund_status       String?
  refund_reason       String?
  buyer_note          String?
  paid_at             String?
  canceled_at         String?
  created_at          String
  updated_at          String
  order_entitlements  order_entitlements[]
  order_items         order_items[]
  order_status_events order_status_events[]
  merchants           merchants             @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users                 @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments            payments[]
  subscriptions       subscriptions[]

  @@index([merchant_id, created_at(sort: Desc)], map: "idx_orders_merchant_created")
  @@index([owner_id, created_at(sort: Desc)], map: "idx_orders_owner_created")
  @@index([owner_id, payment_status, created_at(sort: Desc)], map: "idx_orders_owner_payment_status")
  @@index([owner_id, status, created_at(sort: Desc)], map: "idx_orders_owner_status")
}

model payment_callbacks {
  id              String    @id
  payment_id      String?
  provider        String
  event_type      String
  out_trade_no    String?
  transaction_id  String?
  signature_valid Int       @default(0)
  payload_json    String
  headers_json    String?
  error_message   String?
  created_at      String
  payments        payments? @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([out_trade_no, created_at(sort: Desc)], map: "idx_payment_callbacks_out_trade_created")
  @@index([payment_id, created_at(sort: Desc)], map: "idx_payment_callbacks_payment_created")
}

model payments {
  id                  String              @id
  owner_id            String
  order_id            String
  provider            String
  trade_type          String
  out_trade_no        String              @unique
  prepay_id           String?
  transaction_id      String?
  status              String              @default("created")
  total_amount_cents  Int                 @default(0)
  currency            String              @default("CNY")
  refund_amount_cents Int                 @default(0)
  refund_status       String?
  refund_reason       String?
  raw_request_json    String?
  raw_response_json   String?
  created_at          String
  updated_at          String
  succeeded_at        String?
  closed_at           String?
  payment_callbacks   payment_callbacks[]
  orders              orders              @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users               @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id, created_at(sort: Desc)], map: "idx_payments_order_created")
  @@index([owner_id, status, created_at(sort: Desc)], map: "idx_payments_owner_status_created")
  @@index([transaction_id], map: "idx_payments_transaction_id")
}

model phone_login_codes {
  id         String  @id
  phone      String
  code_salt  String
  code_hash  String
  expires_at String
  used_at    String?
  created_at String
  updated_at String

  @@index([phone, created_at], map: "idx_phone_login_codes_phone_created_at")
  @@index([phone, expires_at], map: "idx_phone_login_codes_phone_expires_at")
}

model points_accounts {
  owner_id     String @id
  balance      Int    @default(0)
  total_earned Int    @default(0)
  total_spent  Int    @default(0)
  updated_at   String
  users        users  @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model points_ledger {
  id              String  @id
  owner_id        String
  change_amount   Int
  balance_after   Int
  source_type     String
  source_id       String?
  note            String?
  idempotency_key String
  created_at      String
  users           users   @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([owner_id, idempotency_key])
  @@index([owner_id, created_at(sort: Desc)], map: "idx_points_ledger_owner_created")
}

model product_entitlements {
  id               String   @id
  product_id       String
  owner_id         String
  entitlement_type String   @default("none")
  config_json      String?
  created_at       String
  updated_at       String
  users            users    @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products         products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([owner_id, product_id])
  @@index([owner_id, entitlement_type], map: "idx_product_entitlements_owner_type")
}

model product_images {
  id         String   @id
  product_id String
  owner_id   String
  image_url  String
  sort_order Int      @default(0)
  created_at String
  updated_at String
  users      users    @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id, sort_order], map: "idx_product_images_product_sort")
}

model product_skus {
  id          String        @id
  product_id  String
  owner_id    String
  merchant_id String
  name        String
  spec        String        @default("")
  price_cents Int           @default(0)
  stock       Int           @default(0)
  is_default  Int           @default(0)
  status      String        @default("active")
  created_at  String
  updated_at  String
  order_items order_items[]
  merchants   merchants     @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users         @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products    products      @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([owner_id], map: "idx_product_skus_owner")
  @@index([product_id], map: "idx_product_skus_product")
}

model products {
  id                   String                 @id
  owner_id             String
  merchant_id          String
  title                String
  subtitle             String?
  description          String?
  currency             String                 @default("CNY")
  price_cents          Int                    @default(0)
  stock                Int                    @default(0)
  status               String                 @default("draft")
  cover_image_url      String?
